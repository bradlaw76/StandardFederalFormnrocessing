{
  "name": "VAFE-Flow-01-SharePointIntake",
  "type": "automated",
  "trigger": {
    "connector": "sharepointonline",
    "operation": "When a file is created (properties only)",
    "siteAddress": "https://d365demotsce80677168.sharepoint.com/sites/DepartmentofVeteranAffairs",
    "libraryName": "FormIntake",
    "triggerCondition": "@startsWith(triggerOutputs()?['body/{FilenameWithExtension}'], 'VA-10-3542-')"
  },
  "actions": [
    {
      "step": 1,
      "name": "Get_file_content",
      "connector": "sharepointonline",
      "operation": "Get file content",
      "inputs": {
        "siteAddress": "https://d365demotsce80677168.sharepoint.com/sites/DepartmentofVeteranAffairs",
        "fileIdentifier": "@{triggerOutputs()?['body/{Identifier}']}"
      }
    },
    {
      "step": 2,
      "name": "Compose_FormId",
      "connector": "built-in",
      "operation": "Compose",
      "inputs": "@{guid()}"
    },
    {
      "step": 3,
      "name": "Create_FormSubmission",
      "connector": "dataverse",
      "operation": "Add a new row",
      "table": "vafe_formsubmission",
      "columns": {
        "vafe_form_id": "@{outputs('Compose_FormId')}",
        "vafe_file_name": "@{triggerOutputs()?['body/{FilenameWithExtension}']}",
        "vafe_file_url": "@{triggerOutputs()?['body/{Link}']}",
        "vafe_file_size": "@{triggerOutputs()?['body/{Size}']}",
        "vafe_submitted_date": "@{utcNow()}",
        "vafe_status": "Intake"
      }
    },
    {
      "step": 4,
      "name": "Create_AuditLog_FileValidated",
      "connector": "dataverse",
      "operation": "Add a new row",
      "table": "vafe_auditlog",
      "columns": {
        "vafe_event_type": "FileValidated",
        "vafe_event_date": "@{utcNow()}",
        "vafe_status": "Success",
        "vafe_details": "@{concat('{\"fileName\":\"', triggerOutputs()?['body/{FilenameWithExtension}'], '\",\"source\":\"SharePoint\"}')}",
        "vafe_retention_days": 90
      }
    },
    {
      "step": 5,
      "name": "Run_Child_Flow_AIExtraction",
      "connector": "flow",
      "operation": "Run a Child Flow",
      "targetFlow": "VAFE-Flow-02-AIExtraction",
      "inputs": {
        "FormSubmissionId": "@{outputs('Create_FormSubmission')?['body/vafe_formsubmissionid']}",
        "FileIdentifier": "@{triggerOutputs()?['body/{Identifier}']}"
      }
    }
  ],
  "successCriteria": [
    "A FormSubmission row exists with Status=Intake",
    "An AuditLog row exists with EventType=FileValidated",
    "Child flow VAFE-Flow-02-AIExtraction is invoked"
  ]
}
