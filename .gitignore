# =============================================================
# .gitignore — Standard Federal Form Processing Repository
# =============================================================
# Tech stack: PowerShell, TypeScript/TSX, Python (utility),
#             Markdown documentation, Power Platform artifacts
# =============================================================

# ─── Node.js / TypeScript ────────────────────────────────────
node_modules/
dist/
build/
.next/
out/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.yarn/
.pnpm-store/

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
*.egg
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt

# ─── PowerShell ──────────────────────────────────────────────
*.ps1xml

# ─── Environment & Secrets ───────────────────────────────────
.env
.env.*
!.env.example
*.secret
*.secret.*
*.key
*.pem
*.p12
*.pfx
local.settings.json

# ─── Power Platform ──────────────────────────────────────────
# Unmanaged solution exports (binary zips) — track in SharePoint/wiki
# Comment out if you want to version control exported solutions here
# *.zip

# ─── OS artifacts ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Editors & IDEs ──────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
!.vscode/extensions.json
!.vscode/settings.default.json
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.swp
*.swo
*~
.project
.classpath
.settings/

# ─── Temporary / Build artifacts ─────────────────────────────
*.tmp
*.temp
*.log
*.bak
*.orig
*.rej
coverage/
.coverage
htmlcov/
.nyc_output/

# ─── Test artifacts ──────────────────────────────────────────
test-results/
playwright-report/
